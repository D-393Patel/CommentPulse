{
  "manifest_version": 3,
  "name": "YouTube Sentiment Insights",
  "version": "1.0.1",
  "description": "Analyzes YouTube video comments for sentiment.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5000/*",
    "http://127.0.0.1:5000/*",
    "https://*.trycloudflare.com/*"
  ]
}
